# ========== HashKey Chain Testnet (hackathon - DeFi track) ==========
# Docs: https://docs.hashkeychain.net/docs/Developer-QuickStart
# RPC_URL must be testnet for wallet balance on dashboard (no trailing slash)
RPC_URL=https://testnet.hsk.xyz
CHAIN_ID=133
CHAIN_DISPLAY_NAME=HashKey Chain Testnet
NATIVE_SYMBOL=HSK

# Wallet address: use your real wallet for the hackathon (read-only, no private key here).
# Dashboard shows your HSK balance. Get testnet HSK: https://faucet.hsk.xyz/faucet
WALLET_ADDRESS=

# ========== HashKey Sandbox (exchange account balance & trades) ==========
HSP_URL=https://hsp.hashkey.chain
HSP_API_KEY=
HSP_SECRET=
# For account balance/trades from sandbox, set both from global.sim.hashkeydev.com → API Management.

# ========== App ==========
FLASK_ENV=development
SECRET_KEY=change-me-in-production
