# HashKey Chain Testnet (hackathon - DeFi track). Docs: https://docs.hashkeychain.net/docs/Developer-QuickStart
RPC_URL=https://testnet.hsk.xyz
CHAIN_ID=133
NATIVE_SYMBOL=HSK

# HSP (PayFi) / HashKey Sandbox (exchange account balance & trades)
HSP_URL=https://hsp.hashkey.chain
HSP_API_KEY=
HSP_SECRET=

# Sandbox: public endpoints work WITHOUT API key. For account balance & trades, set both
# HSP_API_KEY and HSP_SECRET (from User Settings → API Management on global.sim.hashkeydev.com).

# Your wallet address - balance on dashboard (get testnet HSK: https://faucet.hsk.xyz/faucet)
WALLET_ADDRESS=

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
