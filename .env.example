# HashKey Chain RPC (mainnet or testnet)
RPC_URL=https://api.hashkey.chain
# Or use a public EVM-compatible RPC for local dev
# RPC_URL=http://127.0.0.1:8545

# HSP (PayFi) base URL - when API spec is available
HSP_URL=https://hsp.hashkey.chain
HSP_API_KEY=

# HashKey Sandbox: public endpoints work WITHOUT API key (ping, time, exchangeInfo, ticker).
# See docs/API_KEY_SETUP.md. Leave HSP_API_KEY empty to use sandbox for market data only.

# Demo wallet (optional, for read-only balance/tx)
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
